TIMEZONE=Europe/Rome

# SSH
SSH_PORT=22
PERMIT_ROOT_LOGIN=yes
CLIENT_ALIVE_INTERVAL=600
CLIENT_ALIVE_COUNTMAX=2
LOGIN_GRACE_TIME=30

# Root
ROOT_PASSWORD=INSERISCI_PASSWORD_ROOT_QUI          # lascia vuoto per non cambiare

# Firewall
OPEN_HTTP_HTTPS=true    # apri 80/443 oltre alla porta SSH

# Certbot
LETSENCRYPT_EMAIL=INSERISCI_EMAIL_LETSENCRYPT_QUI
LETSENCRYPT_DOMAINS=INSERISCI_DOMINIO_LETSENCRYPT_QUI
WEBSERVER=apache        # apache|nginx|standalone

# NTP
NTP_SERVERS="0.pool.ntp.org 1.pool.ntp.org 2.pool.ntp.org 3.pool.ntp.org"

# Checkmk (opzionale)
CHECKMK_ADMIN_PASSWORD=
CHECKMK_DEB_URL=
CMK_VERSION=2.4.0p1
SITE_NAME=monitoring
