TIMEZONE=Europe/Rome

# SSH
SSH_PORT=22
PERMIT_ROOT_LOGIN=yes
CLIENT_ALIVE_INTERVAL=600
CLIENT_ALIVE_COUNTMAX=2
LOGIN_GRACE_TIME=30

# Root
ROOT_PASSWORD=INSERISCI_PASSWORD_ROOT_QUI          # lascia vuoto per non cambiare

# SMTP relay for Postfix (loopback-only if left empty)
SMTP_RELAYHOST=                     # e.g. [smtp.gmail.com]:587  or leave empty
SMTP_RELAY_USER=                    # relay username/email
SMTP_RELAY_PASSWORD=                # relay password (keep secret!)
SMTP_FROM_ADDRESS=                  # sender rewrite e.g. no-reply@example.com (leave empty to skip)

# Firewall
OPEN_HTTP_HTTPS=true    # apri 80/443 oltre alla porta SSH

# Certbot
LETSENCRYPT_EMAIL=INSERISCI_EMAIL_LETSENCRYPT_QUI
LETSENCRYPT_DOMAINS=INSERISCI_DOMINIO_LETSENCRYPT_QUI
WEBSERVER=apache        # apache|nginx|standalone

# NTP
NTP_SERVERS="0.pool.ntp.org 1.pool.ntp.org 2.pool.ntp.org 3.pool.ntp.org"

# Checkmk (opzionale)
CHECKMK_ADMIN_PASSWORD=
CHECKMK_DEB_URL=
# Download dinamico (se CHECKMK_DEB_URL è vuoto)
# Base URL corretto dove leggere le versioni e scaricare i .deb.
# Esempio (placeholder): https://download.checkmk.com/checkmk
CHECKMK_DOWNLOAD_BASE_URL=INSERISCI_URL_BASE_DOWNLOAD_CHECKMK_QUI
# Header opzionali per accesso (se il sito richiede auth). Formato: "Key: Value; Key2: Value2"
CHECKMK_DOWNLOAD_HEADERS=
CMK_VERSION=latest
SITE_NAME=monitoring

# Apache reverse proxy behavior
REDIRECT_TO_SITE=true

# Local checks deploy (OS-aware)
DEPLOY_LOCAL_CHECKS=true

# Auto git sync (/opt/checkmk-tools)
ENABLE_AUTO_GIT_SYNC=true
AUTO_GIT_SYNC_INTERVAL_SEC=60
AUTO_GIT_SYNC_REPO_URL=https://github.com/Coverup20/checkmk-tools.git
AUTO_GIT_SYNC_TARGET_DIR=/opt/checkmk-tools
