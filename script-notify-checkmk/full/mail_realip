        os.environ["NOTIFY_HOSTADDRESS"] = real_ip
        os.environ["HOSTADDRESS"] = real_ip
    
    service_desc = os.environ.get('NOTIFY_SERVICEDESC', None)
    
    # Determina se è host o service
    if service_desc and service_desc not in ['', 'N/A']:
        # Service notification
        what = os.environ.get('NOTIFY_WHAT', 'SERVICE')
        old_state = os.environ.get('NOTIFY_PREVIOUSSERVICEHARDSHORTSTATE', 'OK')
        new_state = os.environ.get('NOTIFY_SERVICESHORTSTATE', 'UNKNOWN')
        output = os.environ.get('NOTIFY_SERVICEOUTPUT', 'N/A')
        longoutput = os.environ.get('NOTIFY_LONGSERVICEOUTPUT', '')
