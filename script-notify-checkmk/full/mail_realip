def send_email(html_content):
    """Invia l'email HTML"""
    
    # Configurazione SMTP
    smtp_server = os.environ.get('NOTIFY_PARAMETER_SMTP_SERVER', 'localhost')
    smtp_port = int(os.environ.get('NOTIFY_PARAMETER_SMTP_PORT', '25'))
    smtp_user = os.environ.get('NOTIFY_PARAMETER_SMTP_USER', '')
    smtp_password = os.environ.get('NOTIFY_PARAMETER_SMTP_PASSWORD', '')
    from_addr = os.environ.get('NOTIFY_PARAMETER_FROM', 'checkmk@monitoring.local')
    to_addr = os.environ.get('NOTIFY_CONTACTEMAIL', os.environ.get('NOTIFY_PARAMETER_TO', ''))
    
    if not to_addr:
        print("ERROR: No recipient email address configured", file=sys.stderr)
        sys.exit(1)
    
    # Prepara subject
    hostname = os.environ.get('NOTIFY_HOSTNAME', 'Unknown')
    service_desc = os.environ.get('NOTIFY_SERVICEDESC', None)
    notification_type = os.environ.get('NOTIFY_NOTIFICATIONTYPE', 'PROBLEM')
    
    if service_desc and service_desc not in ['', 'N/A']:
        state = os.environ.get('NOTIFY_SERVICESHORTSTATE', 'UNKNOWN')
        subject = f"Checkmk: {hostname}/{service_desc} {state}"
    else:
        state = os.environ.get('NOTIFY_HOSTSHORTSTATE', 'DOWN')
        subject = f"Checkmk: {hostname} {state}"
    
    # Crea messaggio
    msg = MIMEMultipart('alternative')
    msg['Subject'] = subject
    msg['From'] = from_addr
    msg['To'] = to_addr
    
    # Testo plain come fallback
    text_content = f"""
CheckMK Notification

Host: {hostname}
Service: {service_desc if service_desc else 'Host Check'}
State: {state}
Type: {notification_type}

Output:
{os.environ.get('NOTIFY_SERVICEOUTPUT' if service_desc else 'NOTIFY_HOSTOUTPUT', 'N/A')}
"""
    
    part1 = MIMEText(text_content, 'plain', 'utf-8')
    part2 = MIMEText(html_content, 'html', 'utf-8')
    
    msg.attach(part1)
    msg.attach(part2)
    
    # Invia email
    try:
        if smtp_user and smtp_password:
            # SMTP con autenticazione
            server = smtplib.SMTP(smtp_server, smtp_port)
            server.starttls()
            server.send_message(msg)
            server.quit()
        else:
            # SMTP senza autenticazione (localhost)
            server = smtplib.SMTP(smtp_server, smtp_port)
            server.send_message(msg)
            server.quit()
        
        print(f"Email sent successfully to {to_addr}")
        return 0
    
    except Exception as e:
        print(f"ERROR sending email: {e}", file=sys.stderr)
        return 1

def main():
    """Main function"""
    try:
        html_content = build_html_email()
        return send_email(html_content)
    except Exception as e:
        print(f"ERROR in notification script: {e}", file=sys.stderr)
        return 2

if __name__ == "__main__":
    sys.exit(main())
