def get_state_color(state):
    """Restituisce il colore CSS per ogni stato"""
    colors = {
        'OK': '#13d389',
        'UP': '#13d389',
        'WARNING': '#ffd700',
        'WARN': '#ffd700',
        'CRITICAL': '#ff5151',
        'CRIT': '#ff5151',
        'UNKNOWN': '#ff9800',
        'DOWN': '#ff5151',
        'UNREACHABLE': '#ff9800',
    }
    return colors.get(state.upper(), '#666666')

def get_state_label(state):
    """Abbrevia lo stato per il badge"""
    labels = {
        'WARNING': 'WARN',
        'CRITICAL': 'CRIT',
        'UNKNOWN': 'UNKN',
    }
    return labels.get(state.upper(), state.upper())

def format_output(output):
    """Formatta l'output aggiungendo <br> per newline"""
    if not output:
        return "N/A"
    return output.replace('\n', '<br>')

